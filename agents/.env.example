# ========== 服务监听配置 ==========
AGENT_HOST=0.0.0.0
AGENT_PORT=8001
AGENT_RELOAD=false

# ========== API 安全配置 ==========
AGENT_API_KEY=change-me
INTERNAL_API_VERSION=v1
SERVICE_AUTH_MODE=jwt
SERVICE_JWT_TOKEN=change-me

# ========== 后端服务与模型配置 ==========
BACKEND_BASE_URL=http://127.0.0.1:8000
BACKEND_CLIENT_TIMEOUT_SECONDS=10
BACKEND_CLIENT_RETRIES=2
BACKEND_CLIENT_CB_THRESHOLD=5
BACKEND_CLIENT_CB_RECOVERY_SECONDS=30
BACKEND_CLIENT_RATE_LIMIT=200
AGENT_MODEL_NAME=llama3

# ========== 观测与日志 ==========
AGENT_METRICS_DIR=../logs
